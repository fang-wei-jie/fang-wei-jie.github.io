---
import { Image } from 'astro:assets';
import type { Experience } from '../data/portfolio';

interface Props {
  experience: Experience;
  logoLoading?: 'eager' | 'lazy';
}

const { experience, logoLoading = 'lazy' } = Astro.props;
---

<article class="flex justify-center">
  <div class="h-auto w-full rounded-xl transition-all duration-300 ease-in-out" style={`background-color: ${experience.color}1a;`}>
    <div class="relative z-10 grid gap-2 p-5">
      <div class="flex flex-row justify-between gap-3 align-top">
        <div class="min-w-0">
          <h3 class="text-xl font-semibold">{experience.title}</h3>
          <p class="text-md">{experience.duration}</p>
        </div>
        <Image
          class="h-10 w-28 shrink-0 object-contain object-right"
          src={experience.companyLogo}
          alt={`${experience.company} logo`}
          loading={logoLoading}
        />
      </div>

      {
        experience.content.map((content) => (
          <div>
            {content.type && <h4 class="font-semibold">{content.type}</h4>}

            {content.description && (
              <ul class:list={['list-disc px-5', content.type ? 'text-sm' : '']}>
                {content.description.map((paragraph) => <li>{paragraph}</li>)}
              </ul>
            )}

            {content.projects?.map((project) => (
              <div class="py-1 pl-2">
                <p>{project.name}</p>
                <p class="text-sm text-gray-600">
                  {project.description.split('\n').map((line, index) => (
                    index > 0 ? <><br />{line}</> : line
                  ))}
                </p>

                {project.info && (
                  <ul class="list-disc px-5 pt-1 text-sm text-gray-600">
                    {project.info.map((info) => <li>{info}</li>)}
                  </ul>
                )}
              </div>
            ))}
          </div>
        ))
      }

      <div class="mt-2 grid gap-2 border-t border-current/10 pt-3">
        {
          experience.skills.map((group) => (
            <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:gap-3">
              <p class="w-24 shrink-0 text-sm font-semibold text-gray-700">{group.title}</p>
              <div class="flex flex-wrap gap-2">
                {
                  group.skills.map((skill) => (
                    <span class="inline-flex items-center gap-2 rounded-md bg-white/70 px-2 py-1 text-sm text-gray-700">
                      {typeof skill.link === 'string' ? (
                        <Image class="h-4 w-4 shrink-0 object-contain" src={skill.link} alt="" width={16} height={16} loading="lazy" />
                      ) : (
                        <Image class="h-4 w-4 shrink-0 object-contain" src={skill.link} alt="" loading="lazy" />
                      )}
                      <span>{skill.name}</span>
                    </span>
                  ))
                }
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</article>

---
import { skillGroups } from '../data/portfolio';
import SkillList from './SkillList.astro';
---

<section class="px-6 py-5 transition-all duration-300 ease-in-out md:px-14 xl:px-60">
  <h2 class="text-3xl font-bold">Skills</h2>

  <div class="py-10">
    <div class="grid gap-3 transition-all duration-300 ease-in-out sm:grid-cols-2 md:grid-cols-3">
      {
        skillGroups.map((group) => (
          <section>
            <h3 class="pb-3 text-xl font-bold">{group.title}</h3>
            <SkillList skills={group.skills} />
          </section>
        ))
      }
    </div>
  </div>
</section>

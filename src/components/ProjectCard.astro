---
import type { Project } from '../data/portfolio';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="flex h-full w-full justify-center">
  <div class="flex w-full flex-col justify-between rounded-xl bg-white drop-shadow-lg transition-all duration-300 ease-in-out">
    <div class="grid gap-2 p-5">
      <h3 class="text-xl font-semibold">{project.name}</h3>
      <p class="text-lg">{project.description}</p>
    </div>

    <div class="flex justify-between gap-4 p-5">
      {
        project.link && (
          <a
            class="flex w-fit items-center gap-1 transition-all duration-300 ease-in-out hover:font-semibold"
            href={project.link}
            target="_blank"
            rel="noreferrer"
          >
            {project.linkName ?? 'Link'}
            <span class="material-symbols-rounded" aria-hidden="true">open_in_new</span>
          </a>
        )
      }

      {
        project.techStacks.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {project.techStacks.map((stack) => <img class="h-8 object-contain" src={stack.link} alt={stack.name} />)}
          </div>
        )
      }
    </div>
  </div>
</article>
